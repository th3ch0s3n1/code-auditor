# ── Single target (used by docker-compose directly) ──────────────────────────
# docker-compose mounts this as /target inside the container.
TARGET_PATH=C:\Users\yourname\Desktop\myproject

# Where reports are written on the host (maps to /reports inside the container).
REPORTS_PATH=./reports

# ── Multiple targets ──────────────────────────────────────────────────────────
# To scan several projects in one go, list them in targets.txt (one path per
# line, # for comments) and run:  .\scan-all.ps1
# The script sets TARGET_PATH for each entry and invokes docker-compose.
